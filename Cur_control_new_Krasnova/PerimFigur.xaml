<Page x:Class="Cur_control_new_Krasnova.PerimFigur"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Cur_control_new_Krasnova"
      mc:Ignorable="d" 
      d:DesignHeight="230" d:DesignWidth="400"
      Title="PerimFigur">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"></ColumnDefinition>
            <ColumnDefinition Width="1*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <StackPanel Orientation="Horizontal">
                <StackPanel>
                    <TextBlock x:Name="FirstSideText" Text="1-я сторона" Margin="10,10,0,10"/>
                    <TextBlock x:Name="SecondSideText" Text="2-я сторона" Margin="10,10,0,10"/>
                    <TextBlock x:Name="ThirdSideText" Text="3-я сторона" Margin="10,10,0,10"/>
                    <TextBlock x:Name="RadiusText" Text="Радиус" Margin="10,10,0,10"/>
                </StackPanel>
                <StackPanel>
                    <TextBox x:Name="FirstSideTB" Width="100" Margin="10"/>
                    <TextBox x:Name="SecondSideTB" Width="100" Margin="10"/>
                    <TextBox x:Name="ThirdSideTB" Width="100" Margin="10"/>
                    <TextBox x:Name="RadiusTB" Width="100" Margin="10" HorizontalAlignment="Right"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Периметр = " Margin="10"/>
        </StackPanel>

        <StackPanel Grid.Column="1">
            <GroupBox Header="Вид фигуры" Width="180">
                <StackPanel>
                    <RadioButton GroupName="Figs" Content="прямоугольник" Margin="10"/>
                    <RadioButton GroupName="Figs" Content="круг" Margin="10"/>
                    <RadioButton GroupName="Figs" Content="треугольник" Margin="10"/>
                </StackPanel>
            </GroupBox>
            
            <Button x:Name="CalculateBtn" Content="Вычислить" Width="70" Margin="10" HorizontalAlignment="Left"/>
        </StackPanel>

    </Grid>
</Page>
